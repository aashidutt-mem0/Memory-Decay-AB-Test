# Single-project mode:
MEM0_API_KEY=your_mem0_project_key

# Optional cleaner A/B mode with two separate projects:
MEM0_API_KEY_OFF=your_decay_off_key
MEM0_API_KEY_ON=your_decay_on_key
MEM0_API_HOST=https://api.mem0.ai

# Optional: only needed when running with --llm-judge.
AZURE_OPENAI_ENDPOINT=https://your-resource-name.openai.azure.com
AZURE_OPENAI_API_KEY=your_azure_openai_key
AZURE_OPENAI_API_VERSION=2024-12-01-preview
AZURE_OPENAI_DEPLOYMENT_GPT4O_MINI=gpt-4o-mini
AZURE_OPENAI_DEPLOYMENT_GPT5_MINI=gpt-5-mini
